*.bash text eol=lf

# Fichiers texte standard
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.env* text eol=lf
Dockerfile* text eol=lf
