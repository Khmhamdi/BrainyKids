generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  password_hash String
  role          String
  full_name     String
  email         String   @unique
  phone         String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  teachers      Teacher[]
  parents       Parent[]
  notifications Notification[]
}

model Teacher {
  id              String               @id @default(uuid())
  user_id         String?              @unique
  full_name       String?
  hire_date       DateTime
  departure_date  DateTime?
  qualification   String?
  fonction        String               @default("enseignante")
  photo_url       String?
  monthly_salary  Decimal?             @db.Decimal(10, 2)
  user            User?                @relation(fields: [user_id], references: [id])
  classes         Class[]
  evaluations     Evaluation[]
  salary_payments StaffSalaryPayment[]
}

model StaffSalaryPayment {
  id          String    @id @default(uuid())
  teacher_id  String
  month       Int
  year        Int
  amount      Decimal   @db.Decimal(10, 2)
  paid_at     DateTime?
  notes       String?
  created_at  DateTime  @default(now())
  teacher     Teacher   @relation(fields: [teacher_id], references: [id])
}

model Class {
  id          String    @id @default(uuid())
  name        String
  teacher_id  String
  age_group   String
  room_number String
  schedule_id String?
  teacher     Teacher   @relation(fields: [teacher_id], references: [id])
  schedule    Schedule? @relation(fields: [schedule_id], references: [id])
  students    Student[]
}

model Student {
  id                        String    @id @default(uuid())
  full_name                 String
  date_of_birth             DateTime
  class_id                  String
  grade                     String
  gender                    String    @default("M")
  schedule_id               String?
  registration_date         DateTime
  medical_file_id           String?
  registration_checklist_id String?
  photo_url                 String?
  regime                    String    @default("journee_complete")
  lieu_naissance            String?
  nationalite               String?   @default("Tunisienne")
  numero_inscription        String?   @unique
  heure_arrivee             String?
  heure_depart              String?
  transport_mode            String?   @default("parent")
  archived                  Boolean   @default(false)
  archived_at               DateTime?
  archived_by               String?
  unregistered_at           DateTime?
  unregistered_reason       String?
  class                     Class     @relation(fields: [class_id], references: [id])
  schedule                  Schedule? @relation(fields: [schedule_id], references: [id])
  medical_file              MedicalFile?
  registration_checklist    RegistrationChecklist?
  student_parents           StudentParent[]
  absences                  Absence[]
  health_tracking           HealthTracking[]
  payments                  Payment[]
  club_memberships          ClubMembership[]
  event_registrations       EventRegistration[]
  evaluations               Evaluation[]
  specialized_followup      SpecializedFollowUp?
  student_pack              StudentPack?
  summer_packs              SummerPack[]
  notes                     StudentNote[]
}

model Parent {
  id              String    @id @default(uuid())
  full_name       String
  gender          String    @default("father")
  marital_status  String    @default("alive")
  family_name     String?
  email           String
  phone           String
  address         String?
  cin             String?
  profession      String?
  user_id         String
  archived        Boolean   @default(false)
  archived_at     DateTime?
  archived_by     String?
  user            User      @relation(fields: [user_id], references: [id])
  student_parents StudentParent[]
  payments        Payment[]
}

model StudentParent {
  id           String  @id @default(uuid())
  student_id   String
  parent_id    String
  relationship String
  student      Student @relation(fields: [student_id], references: [id])
  parent       Parent  @relation(fields: [parent_id], references: [id])
  @@unique([student_id, parent_id])
}

model Schedule {
  id           String   @id @default(uuid())
  name         String
  description  String
  start_time   String
  end_time     String
  days_of_week String
  classes      Class[]
  students     Student[]
}

model MedicalFile {
  id                     String   @id @default(uuid())
  student_id             String   @unique
  allergies              String   @default("")
  chronic_conditions     String   @default("")
  vaccinations           String   @default("")
  emergency_contact      String   @default("")
  last_update            DateTime
  has_allergies          Boolean  @default(false)
  allergies_detail       String?
  traitement             Boolean  @default(false)
  traitement_detail      String?
  condition_particuliere String?
  medecin_traitant       String?
  tel_medecin            String?
  email_medecin          String?
  student                Student  @relation(fields: [student_id], references: [id])
}

model RegistrationChecklist {
  id                         String   @id @default(uuid())
  student_id                 String   @unique
  photo_identite             Boolean  @default(false)
  extrait_naissance          Boolean  @default(false)
  certificat_medical         Boolean  @default(false)
  fiche_renseignement_signee Boolean  @default(false)
  vaccinations_a_jour        Boolean  @default(false)
  copie_cin_pere             Boolean  @default(false)
  copie_cin_mere             Boolean  @default(false)
  completed                  Boolean  @default(false)
  last_update                DateTime @updatedAt
  student                    Student  @relation(fields: [student_id], references: [id])
}

model Evaluation {
  id          String             @id @default(uuid())
  student_id  String
  teacher_id  String
  date        DateTime
  criteria_id String
  score       Int
  comments    String
  student     Student            @relation(fields: [student_id], references: [id])
  teacher     Teacher            @relation(fields: [teacher_id], references: [id])
  criteria    EvaluationCriteria @relation(fields: [criteria_id], references: [id])
}

model EvaluationCriteria {
  id          String       @id @default(uuid())
  age_group   String
  description String
  max_score   Int
  evaluations Evaluation[]
}

model Absence {
  id                  String   @id @default(uuid())
  student_id          String
  date                DateTime
  reason              String
  excused             Boolean  @default(false)
  medical_certificate Boolean  @default(false)
  apt_to_return       Boolean  @default(false)
  notes               String?
  recorded_by         String?
  student             Student  @relation(fields: [student_id], references: [id])
}

model HealthTracking {
  id         String   @id @default(uuid())
  student_id String
  date       DateTime
  temperature Float
  symptoms   String
  notes      String
  student    Student  @relation(fields: [student_id], references: [id])
}

model Payment {
  id          String    @id @default(uuid())
  student_id  String
  parent_id   String?
  type        String
  amount      Float
  due_date    DateTime
  paid_date   DateTime?
  status      String    @default("pending")
  description String?
  note        String?
  month       Int?
  year        Int?
  student     Student   @relation(fields: [student_id], references: [id])
  parent      Parent?   @relation(fields: [parent_id], references: [id])
}

model Club {
  id          String           @id @default(uuid())
  name        String
  description String?
  price       Float            @default(0)
  age_group   String?
  type        String           @default("regulier")  // "regulier" | "ete"
  is_active   Boolean          @default(true)
  memberships ClubMembership[]
}

model AppLookup {
  id         String  @id @default(uuid())
  category   String  // "regime" | "age_group" | "fonction"
  code       String
  label      String
  sort_order Int     @default(0)
  is_active  Boolean @default(true)
  meta       Json?
  @@unique([category, code])
}

model ClubMembership {
  id         String   @id @default(uuid())
  club_id    String
  student_id String
  join_date  DateTime
  paid       Boolean
  club       Club     @relation(fields: [club_id], references: [id])
  student    Student  @relation(fields: [student_id], references: [id])
  @@unique([club_id, student_id])
}

model Event {
  id               String              @id @default(uuid())
  name             String
  description      String
  event_date       DateTime
  location         String
  registration_fee Float
  registrations    EventRegistration[]
}

model EventRegistration {
  id                String   @id @default(uuid())
  event_id          String
  student_id        String
  registration_date DateTime
  paid              Boolean
  event             Event    @relation(fields: [event_id], references: [id])
  student           Student  @relation(fields: [student_id], references: [id])
  @@unique([event_id, student_id])
}

model SpecializedFollowUp {
  id                  String   @id @default(uuid())
  student_id          String   @unique
  type                String   // pedo_psy | orthophoniste | ergotherapeute | psychomotricien | autre
  specialist_name     String
  specialist_phone    String?
  specialist_email    String?
  frequency           String?  // hebdo | bimensuel | mensuel | ponctuel
  class_recommendations String?
  notes               String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  student             Student  @relation(fields: [student_id], references: [id])
}

model StudentPack {
  id                  String   @id @default(uuid())
  student_id          String   @unique
  scolarite_amount    Float    @default(0)
  cantine_enabled     Boolean  @default(false)
  cantine_amount      Float    @default(0)
  transport_enabled   Boolean  @default(false)
  transport_amount    Float    @default(0)
  clubs               Json     @default("[]")
  discount            Float    @default(0)
  inscription_amount  Float    @default(0)
  inscription_paid    Boolean  @default(false)
  school_year         String
  start_month         Int      @default(9)
  end_month           Int      @default(6)
  regime              String   @default("journee_complete")
  tarif_base          Float    @default(0)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  student             Student  @relation(fields: [student_id], references: [id])
}

model ExternalStudent {
  id            String    @id @default(uuid())
  full_name     String
  date_of_birth DateTime
  gender        String    @default("M")
  parent_name   String
  parent_phone  String
  parent_email  String?
  address       String?
  created_at    DateTime  @default(now())
  summer_packs  SummerPack[]
}

model SummerPack {
  id                   String           @id @default(uuid())
  student_id           String?
  external_student_id  String?
  month                Int
  year                 Int
  pack_amount          Float            @default(0)
  clubs_json           Json             @default("[]")  // [{clubId, name, price}]
  langue_fr            Boolean          @default(false)
  langue_fr_amount     Float            @default(0)
  langue_en            Boolean          @default(false)
  langue_en_amount     Float            @default(0)
  robotique            Boolean          @default(false)
  robotique_amount     Float            @default(0)
  total_amount         Float            @default(0)
  paid                 Boolean          @default(false)
  paid_date            DateTime?
  created_at           DateTime         @default(now())
  student              Student?         @relation(fields: [student_id], references: [id])
  external_student     ExternalStudent? @relation(fields: [external_student_id], references: [id])
}

model StudentNote {
  id         String   @id @default(uuid())
  student_id String
  date       DateTime @default(now())
  content    String
  author     String?
  student    Student  @relation(fields: [student_id], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  user_id     String
  title       String
  message     String
  type        String
  link        String?
  read        Boolean  @default(false)
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
}

model PreRegistration {
  id               String    @id @default(uuid())
  child_full_name  String
  date_of_birth    DateTime
  gender           String    @default("M")
  desired_class    String
  school_year      String
  parent_full_name String
  parent_phone     String
  parent_email     String
  parent_relation  String    @default("father")
  message          String?
  status           String    @default("pending")
  rejection_reason String?
  created_at       DateTime  @default(now())
  processed_at     DateTime?
  processed_by     String?
}
